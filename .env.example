# ──────────────────────────────────────────────────────────────────────
# 🚀 SRE ARCHITECTURE - Environment Variables Template
# ──────────────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores.
# NUNCA subas .env a Git (ya está en .gitignore).
# ──────────────────────────────────────────────────────────────────────

APP_ENV=production

# ─── BASE DE DATOS MYSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario
DB_PASS=tu_contraseña

# ─── SITIO ──────────────────────────────────────────────────────────
SITE_URL=https://tudominio.com
SITE_NAME=Tu Sistema de Tickets
ADMIN_EMAIL=admin@tudominio.com

# ─── PHPMAILER (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USERNAME=tu_usuario@tudominio.com
SMTP_PASSWORD=tu_contraseña_smtp
SMTP_FROM_EMAIL=no-reply@tudominio.com
SMTP_FROM_NAME=Tu Empresa

# ─── REDIS CACHE (Upstash) ──────────────────────────────────────────
# Crea DB en: https://console.upstash.com/redis
REDIS_REST_URL=https://TU-INSTANCIA.upstash.io
REDIS_REST_TOKEN=TU_TOKEN_DE_UPSTASH

# ─── QSTASH (Cola de Mensajes) ──────────────────────────────────────
# Crea proyecto en: https://console.upstash.com/qstash
UPSTASH_QSTASH_TOKEN=TU_QSTASH_TOKEN
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=sig_TU_SIGNING_KEY
QSTASH_NEXT_SIGNING_KEY=sig_TU_NEXT_KEY
QUEUE_WORKER_URL=https://tudominio.com/queue_worker.php

# ─── CLOUDFLARE D1 (Migración Zero-Downtime) ────────────────────────
D1_SYNC_URL=https://tudominio.com/api/d1-sync
D1_SYNC_TOKEN=TU_TOKEN_SEGURO
