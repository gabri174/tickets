# ──────────────────────────────────────────────────────────────────────
# 🚀 SRE ARCHITECTURE - Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copia este archivo como .env en tu servidor y rellena los valores.
# NUNCA subas .env a Git (ya está en .gitignore).
# ──────────────────────────────────────────────────────────────────────

APP_ENV=production

# ─── CAPA 1: Redis Cache ────────────────────────────────────────────
# Opción A: Upstash Redis (recomendado, sin extensión PHP necesaria)
# → Crea un DB en: https://console.upstash.com/redis
REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
REDIS_REST_TOKEN=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA=

# Opción B: Redis local (si tienes Redis en tu servidor)
# REDIS_URL=tcp://127.0.0.1:6379

# ─── CAPA 2: Upstash QStash (Cola de Mensajes) ─────────────────────
# → Crea un proyecto QStash en: https://console.upstash.com/qstash
UPSTASH_QSTASH_TOKEN=eyJVc2VySWQiOiJTVUJTVElUVVRFX1dJVEhfWU9VUl9UT0tFTiJ9...
QSTASH_SIGNING_KEY=sig_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL pública donde QStash puede hacer POST al worker
QUEUE_WORKER_URL=https://ensupresencia.eu/queue_worker.php
